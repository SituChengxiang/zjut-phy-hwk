// 物理常数模块
// Physics Constants Module

// 光速 (Speed of light)
#let c = $c$

// 普朗克常数 (Planck constant)
#let h = $h$

// 约化普朗克常数 (Reduced Planck constant)
// Typst 中 $planck$ 即为 ħ
#let hbar = $planck$

// 电子电荷 (Elementary charge)
#let e = $e$

// 玻尔兹曼常数 (Boltzmann constant)
#let k_B = $k_"B"$

// 引力常数 (Gravitational constant)
#let G = $G$

// 真空介电常数 (Vacuum permittivity)
#let epsilon_0 = $epsilon_0$

// 真空磁导率 (Vacuum permeability)
#let mu_0 = $mu_0$

// 电子质量 (Electron mass)
#let m_e = $m_e$

// 质子质量 (Proton mass)
#let m_p = $m_p$

// 中子质量 (Neutron mass)
#let m_n = $m_n$

// 精细结构常数 (Fine-structure constant)
#let alpha = $alpha$

// 阿伏伽德罗常数 (Avogadro constant)
#let N_A = $N_"A"$

// 气体常数 (Gas constant)
#let R = $R$

// 斯特藩-玻尔兹曼常数 (Stefan-Boltzmann constant)
#let sigma = $sigma$

// 维恩位移常数 (Wien displacement constant)
#let b = $b$

// 玻尔半径 (Bohr radius)
#let a_0 = $a_0$

// 里德伯常数 (Rydberg constant)
#let R_infty = $R_infinity$

// 核磁子 (Nuclear magneton)
#let mu_N = $mu_N$

// 玻尔磁子 (Bohr magneton)
#let mu_B = $mu_B$
